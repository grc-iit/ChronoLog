# ChronoLog Grafana Backend Configuration
# Copy this file to .env and modify as needed

# Server settings
HOST=0.0.0.0
PORT=8080

# ChronoLog library path (where py_chronolog_client.so is located)
CHRONOLOG_LIB_PATH=/home/kfeng/chronolog-install/chronolog/lib

# ChronoLog service connection settings
CHRONOLOG_PROTOCOL=ofi+sockets

# Portal service configuration
CHRONOLOG_PORTAL_IP=127.0.0.1
CHRONOLOG_PORTAL_PORT=5555
CHRONOLOG_PORTAL_PROVIDER_ID=55

# Query service configuration
CHRONOLOG_QUERY_IP=127.0.0.1
CHRONOLOG_QUERY_PORT=5557
CHRONOLOG_QUERY_PROVIDER_ID=57

# Auto-connect on startup (true/false)
CHRONOLOG_AUTO_CONNECT=false

