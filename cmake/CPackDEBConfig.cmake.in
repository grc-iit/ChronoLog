# =============================================================================
# CPack DEB configuration for ChronoLog
# Auto-generated by CMake from cmake/CPackDEBConfig.cmake.in — do not edit.
# Invoked by the package_release custom target via:
#   cpack --config <build>/CPackDEBConfig.cmake -G DEB
#
# Install layout on target system: /opt/chronolog/
# All non-system runtime libraries are bundled (self-contained package).
# System dependency: libjson-c (available in all major Debian-based distros).
# =============================================================================

# --- General package metadata ------------------------------------------------
set(CPACK_PACKAGE_NAME        "chronolog")
set(CPACK_PACKAGE_VENDOR      "GRC-IIT, Illinois Institute of Technology")
set(CPACK_PACKAGE_CONTACT     "eneko.gonzalez@iit.edu")
set(CPACK_PACKAGE_VERSION     "@CHRONOLOG_PACKAGE_VERSION@")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY
    "ChronoLog: Distributed Chronicle Logging System")
set(CPACK_RESOURCE_FILE_LICENSE "@CMAKE_SOURCE_DIR@/LICENSE")
set(CPACK_RESOURCE_FILE_README  "@CMAKE_SOURCE_DIR@/README.md")

# --- Generator ---------------------------------------------------------------
set(CPACK_GENERATOR "DEB")

# Disable CPack's own cmake --install; package the tree already prepared by
# install.sh (cmake --install + copy_shared_libs + update_rpath).
set(CPACK_INSTALL_CMAKE_PROJECTS "")
set(CPACK_INCLUDE_TOPLEVEL_DIRECTORY OFF)

# Source: pre-prepared install tree.
# Destination "opt/chronolog" → /opt/chronolog on the target system.
set(CPACK_INSTALLED_DIRECTORIES
    "@CMAKE_INSTALL_PREFIX@/chronolog"
    "opt/chronolog"
)

# Filename convention: name_version-release_arch  (no .deb suffix — CPack adds it)
# Debian uses "amd64" where RPM uses "x86_64"; CHRONOLOG_DEB_ARCH is set by
# the arch-mapping block in root CMakeLists.txt before configure_file() is called.
set(CPACK_PACKAGE_FILE_NAME
    "chronolog_@CHRONOLOG_PACKAGE_VERSION@-1_@CHRONOLOG_DEB_ARCH@")

# --- DEB-specific settings ---------------------------------------------------
set(CPACK_DEBIAN_PACKAGE_RELEASE      "1")
set(CPACK_DEBIAN_PACKAGE_MAINTAINER   "eneko.gonzalez@iit.edu")
set(CPACK_DEBIAN_PACKAGE_SECTION      "net")
set(CPACK_DEBIAN_PACKAGE_ARCHITECTURE "@CHRONOLOG_DEB_ARCH@")

# Only libjson-c is a true system dependency; all Spack-managed libraries are
# bundled in /opt/chronolog/lib/ with $ORIGIN/../lib RPATH entries.
# libjson-c5 is the package name on Ubuntu 22.04+/Debian 12+.
set(CPACK_DEBIAN_PACKAGE_DEPENDS "libjson-c5 (>= 0.13)")

set(CPACK_DEBIAN_PACKAGE_DESCRIPTION
"ChronoLog: Distributed Chronicle Logging System
 Distributed, hierarchical, and tiered chronicle-based logging system designed
 for high-performance recording and playback of time-ordered event streams
 across HPC clusters.
 .
 Installed to /opt/chronolog (self-contained: all non-system libraries bundled).
 .
 Components: ChronoVisor, ChronoKeeper, ChronoGrapher, ChronoPlayer,
             chronolog_client library, ChronoKVS plugin.")
