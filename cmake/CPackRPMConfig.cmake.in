# =============================================================================
# CPack RPM configuration for ChronoLog
# Auto-generated by CMake from cmake/CPackRPMConfig.cmake.in — do not edit.
# Invoked by the package_release custom target via:
#   cpack --config <build>/CPackRPMConfig.cmake -G RPM
#
# Install layout on target system: /opt/chronolog/
# All non-system runtime libraries are bundled (self-contained package).
# System dependency: libjson-c (available in all major RPM-based distros).
# =============================================================================

# --- General package metadata ------------------------------------------------
set(CPACK_PACKAGE_NAME        "chronolog")
set(CPACK_PACKAGE_VENDOR      "GRC-IIT, Illinois Institute of Technology")
set(CPACK_PACKAGE_CONTACT     "egonzalez30@illinoistech.edu")
set(CPACK_PACKAGE_VERSION     "@CHRONOLOG_PACKAGE_VERSION@")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY
    "ChronoLog: Distributed Chronicle Logging System")
set(CPACK_RESOURCE_FILE_LICENSE "@CMAKE_SOURCE_DIR@/LICENSE")
set(CPACK_RESOURCE_FILE_README  "@CMAKE_SOURCE_DIR@/README.md")

# --- Generator ---------------------------------------------------------------
set(CPACK_GENERATOR "RPM")

# Disable CPack's own cmake --install; package the tree already prepared by
# install.sh (cmake --install + copy_shared_libs + update_rpath).
set(CPACK_INSTALL_CMAKE_PROJECTS "")
set(CPACK_INCLUDE_TOPLEVEL_DIRECTORY OFF)

# Source: pre-prepared install tree.
# Destination "opt/chronolog" → /opt/chronolog on the target system.
set(CPACK_INSTALLED_DIRECTORIES
    "@CMAKE_INSTALL_PREFIX@/chronolog"
    "opt/chronolog"
)

# Filename convention: name-version-release.arch  (no .rpm suffix — CPack adds it)
set(CPACK_PACKAGE_FILE_NAME
    "chronolog-@CHRONOLOG_PACKAGE_VERSION@-1.@CMAKE_SYSTEM_PROCESSOR@")

# --- RPM-specific settings ---------------------------------------------------
set(CPACK_RPM_PACKAGE_RELEASE      "1")
set(CPACK_RPM_PACKAGE_LICENSE      "BSD-2-Clause")
set(CPACK_RPM_PACKAGE_GROUP        "System Environment/Daemons")
set(CPACK_RPM_PACKAGE_ARCHITECTURE "@CMAKE_SYSTEM_PROCESSOR@")

# /opt prefix tells rpmbuild where the package installs relative to /.
set(CPACK_RPM_PACKAGE_PREFIX "/opt")

# Only json-c is a true system dependency; all Spack-managed libraries are
# bundled in /opt/chronolog/lib/ with $ORIGIN/../lib RPATH entries.
set(CPACK_RPM_PACKAGE_REQUIRES "json-c >= 0.13")

set(CPACK_RPM_PACKAGE_DESCRIPTION
"ChronoLog is a distributed, hierarchical, and tiered chronicle-based logging
system designed for high-performance recording and playback of time-ordered
event streams across HPC clusters.

Installed to /opt/chronolog (self-contained: all non-system libraries bundled).

Components: ChronoVisor, ChronoKeeper, ChronoGrapher, ChronoPlayer,
            chronolog_client library, ChronoKVS plugin.")
