@PACKAGE_INIT@

# Find required dependencies before including targets
# spdlog is a PUBLIC dependency (public headers include spdlog headers)
find_dependency(spdlog REQUIRED)

# json-c is needed for public headers (ClientConfiguration.h includes json-c/json.h)
# We use pkg-config for json-c as it's typically not a CMake package
find_package(PkgConfig QUIET)
if(PkgConfig_FOUND)
    pkg_check_modules(JSON-C QUIET json-c)
endif()

# Include the exported targets
# This must come after finding dependencies since the targets reference them
include("${CMAKE_CURRENT_LIST_DIR}/ChronologTargets.cmake")

# Check required components (if any were requested)
# Since we don't have components, we just ensure the target exists
if(NOT TARGET Chronolog::chronolog_client)
    set(Chronolog_FOUND FALSE)
    set(Chronolog_NOT_FOUND_MESSAGE "Chronolog::chronolog_client target not found")
else()
    set(Chronolog_FOUND TRUE)
endif()

# Set variables for backward compatibility and convenience
set(Chronolog_VERSION "@CHRONOLOG_PACKAGE_VERSION@")
set(Chronolog_VERSION_MAJOR "@CHRONOLOG_VERSION_MAJOR@")
set(Chronolog_VERSION_MINOR "@CHRONOLOG_VERSION_MINOR@")
set(Chronolog_VERSION_PATCH "@CHRONOLOG_VERSION_PATCH@")

# Provide include directory (for compatibility)
# Note: Modern CMake should use Chronolog::chronolog_client target directly
set(Chronolog_INCLUDE_DIRS "@PACKAGE_CHRONOLOG_INSTALL_INCLUDE_DIR@")

# Provide library (for compatibility)
# Note: Modern CMake should use Chronolog::chronolog_client target directly
set(Chronolog_LIBRARIES Chronolog::chronolog_client)

# Provide library directory (for compatibility)
set(Chronolog_LIBRARY_DIRS "@PACKAGE_CHRONOLOG_INSTALL_LIB_DIR@")

