---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'ChronoLog — A distributed shared tiered log store that uses physical time as the ordering mechanism. NSF-funded open-source cyberinfrastructure for HPC, scientific computing, and AI agent memory.',
  keywords = 'ChronoLog, distributed log, shared log, tiered storage, physical time ordering, HPC, activity data, NSF',
  ogImage = '/images/chronolog-full-logo.png',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const fullTitle = title === 'Home' ? 'ChronoLog — Distributed Shared Tiered Log Store' : `${title} | ChronoLog`;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/use-cases/', label: 'Use Cases' },
  { href: '/architecture/', label: 'Architecture' },
  { href: '/docs/', label: 'Docs' },
  { href: '/about/', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Gnosis Research Center, Illinois Institute of Technology" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/images/chronolog-favicon.png" />
    <link rel="apple-touch-icon" href="/images/chronolog-favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="ChronoLog" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta name="twitter:site" content="@grc_iit" />

    <!-- Preconnect & Preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet" />

    <!-- AI / Agent discoverability -->
    <link rel="help" href="/llms.txt" type="text/plain" title="LLM-readable project summary" />

    <!-- JSON-LD Structured Data -->
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map(ld => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)
        : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-bg/80 backdrop-blur-lg border-b border-border">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo (text only) -->
        <a href="/" class="flex items-center gap-3 group">
          <span class="text-xl font-bold text-lime tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">ChronoLog</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                currentPath === link.href
                  ? 'bg-lime/15 text-lime'
                  : 'text-text-muted hover:text-text hover:bg-white/5'
              ]}
            >
              {link.label}
            </a>
          ))}
          <a
            href="https://github.com/grc-iit/ChronoLog"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-3 px-3 py-2 rounded-lg text-sm font-medium text-text-muted hover:text-text hover:bg-white/5 transition-colors flex items-center gap-1.5"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-text-muted hover:text-text" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-bg">
        <div class="px-6 py-4 flex flex-col gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                currentPath === link.href
                  ? 'bg-lime/15 text-lime'
                  : 'text-text-muted hover:text-text hover:bg-white/5'
              ]}
            >
              {link.label}
            </a>
          ))}
          <a href="https://github.com/grc-iit/ChronoLog" target="_blank" rel="noopener noreferrer" class="px-3 py-2 rounded-lg text-sm font-medium text-text-muted hover:text-text hover:bg-white/5 flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border bg-bg-alt">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Branding -->
          <div>
            <a href="/" class="flex items-center gap-3 mb-4">
              <img src="/images/chronolog-logo-no-background.png" alt="ChronoLog logo — distributed shared tiered log store" class="h-20 rounded" />
            </a>
            <p class="text-sm text-text-muted leading-relaxed">
              A distributed and tiered shared log storage ecosystem. Funded by NSF (CSSI-2104013).
            </p>
          </div>
          <!-- Links -->
          <div>
            <h4 class="text-sm font-semibold text-text mb-3">Project</h4>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><a href="/architecture/" class="hover:text-lime transition-colors">Architecture</a></li>
              <li><a href="/use-cases/" class="hover:text-lime transition-colors">Use Cases</a></li>
              <li><a href="/docs/" class="hover:text-lime transition-colors">Documentation</a></li>
              <li><a href="https://github.com/grc-iit/ChronoLog" target="_blank" class="hover:text-lime transition-colors">GitHub</a></li>
            </ul>
          </div>
          <!-- GRC -->
          <div>
            <h4 class="text-sm font-semibold text-text mb-3">Gnosis Research Center</h4>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><a href="https://grc.iit.edu" target="_blank" class="hover:text-lime transition-colors">Website</a></li>
              <li><a href="https://twitter.com/grc_iit" target="_blank" class="hover:text-lime transition-colors">X (Twitter)</a></li>
              <li><a href="https://www.linkedin.com/school/gnosis-research-center" target="_blank" class="hover:text-lime transition-colors">LinkedIn</a></li>
              <li><a href="mailto:grc@illinoistech.edu" class="hover:text-lime transition-colors">grc@illinoistech.edu</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 pt-6 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-text-muted">
          <p>&copy; {new Date().getFullYear()} Gnosis Research Center, Illinois Institute of Technology</p>
          <div class="flex items-center gap-2">
            <img src="/images/logos/nsf.png" alt="NSF" class="h-6" />
            <span>NSF CSSI-2104013</span>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
