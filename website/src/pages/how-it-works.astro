          <text x="304" y="89" text-anchor="middle" fill="#e8eaed" font-size="7">E4</text>
          <rect x="408" y="77" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
          <text x="424" y="89" text-anchor="middle" fill="#e8eaed" font-size="7">E7</text>
          <rect x="528" y="77" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
          <text x="544" y="89" text-anchor="middle" fill="#e8eaed" font-size="7">E10</text>

          <!-- Story: Temperature — contains E3, E6, E9, E11, E12 -->
          <rect x="24" y="112" width="636" height="32" rx="5" fill="#252b3b" stroke="#4a90a4" stroke-width="0.75"/>
          <text x="34" y="124" fill="#a0c8d8" font-size="8" font-weight="600">Story "Temperature"</text>
          <rect x="248" y="117" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
          <text x="264" y="129" text-anchor="middle" fill="#e8eaed" font-size="7">E3</text>
          <rect x="368" y="117" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
          <text x="384" y="129" text-anchor="middle" fill="#e8eaed" font-size="7">E6</text>
          <rect x="488" y="117" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
          <text x="504" y="129" text-anchor="middle" fill="#e8eaed" font-size="7">E9</text>
          <rect x="568" y="117" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
          <text x="584" y="129" text-anchor="middle" fill="#e8eaed" font-size="7">E11</text>
          <rect x="608" y="117" width="32" height="16" rx="4" fill="#1e2330" stroke="#c3e04d" stroke-width="0.75" stroke-opacity="0.5"/>
