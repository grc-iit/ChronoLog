          <text x="152" y="165" text-anchor="end" fill="#c3e04d" fill-opacity="0.5" font-size="7">time</text>

          <!-- Time tick marks aligned with events -->
          <line x1="184" y1="159" x2="184" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="184" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t1</text>
          <line x1="224" y1="159" x2="224" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="224" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t2</text>
          <line x1="264" y1="159" x2="264" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="264" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t3</text>
          <line x1="304" y1="159" x2="304" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="304" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t4</text>
          <line x1="344" y1="159" x2="344" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="344" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t5</text>
          <line x1="384" y1="159" x2="384" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="384" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t6</text>
          <line x1="424" y1="159" x2="424" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="424" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t7</text>
          <line x1="464" y1="159" x2="464" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="464" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t8</text>
          <line x1="504" y1="159" x2="504" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="504" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t9</text>
          <line x1="544" y1="159" x2="544" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="544" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t10</text>
          <line x1="584" y1="159" x2="584" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="584" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t11</text>
          <line x1="624" y1="159" x2="624" y2="165" stroke="#c3e04d" stroke-width="0.5" stroke-opacity="0.3"/>
          <text x="624" y="174" text-anchor="middle" fill="#c3e04d" fill-opacity="0.35" font-size="6">t12</text>
        </svg>
      </div>

      <p class="text-text-muted text-xs text-center">
        <a href="https://github.com/grc-iit/ChronoLog/wiki/05.-Client-API" target="_blank" class="text-lime hover:underline">Learn more in the docs &rarr;</a>
      </p>
    </div>
  </section>

  <!-- 4. Software Architecture -->
  <section class="bg-bg-alt border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl font-bold mb-4">Software Architecture</h2>
      <p class="text-text-muted text-sm leading-relaxed max-w-3xl mb-8">The data model defines what ChronoLog stores &mdash; the architecture defines how. Five distributed services form a pipeline from ingestion to archival. Data flows through time-ordered tiers automatically.</p>

      <!-- Data flow pipeline -->
      <div class="flex flex-col md:flex-row items-stretch gap-3 mb-12">
        <!-- Client -->
        <div class="flex-1 bg-bg-card border border-border rounded-xl p-5 relative">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-text-muted"></div>
            <h3 class="font-bold text-sm text-text">Client App</h3>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Your application. Uses <strong class="text-text">libchronolog</strong> (C++ or Python) to create chronicles, record events, and replay history.</p>
          <div class="hidden md:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10 text-lime">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </div>
        </div>
        <!-- ChronoVisor -->
        <div class="flex-1 bg-bg-card border border-lime/30 rounded-xl p-5 relative">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-lime"></div>
            <h3 class="font-bold text-sm text-lime">ChronoVisor</h3>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Central coordination: chronicle metadata, client connections, and <strong class="text-text">distributed clock synchronization</strong> across all nodes.</p>
          <div class="hidden md:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10 text-lime">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </div>
        </div>
        <!-- ChronoKeeper -->
        <div class="flex-1 bg-bg-card border border-lime/30 rounded-xl p-5 relative">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-lime"></div>
            <h3 class="font-bold text-sm text-lime">ChronoKeeper</h3>
            <span class="text-[10px] text-text-muted bg-bg/50 px-1.5 py-0.5 rounded">Hot</span>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Fast ingestion on compute nodes via <strong class="text-text">RDMA</strong>. Serves record() and real-time playback() with microsecond latency.</p>
          <div class="hidden md:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10 text-lime">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </div>
        </div>
        <!-- ChronoGrapher -->
        <div class="flex-1 bg-bg-card border border-lime/30 rounded-xl p-5 relative">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-lime"></div>
            <h3 class="font-bold text-sm text-lime">ChronoGrapher</h3>
            <span class="text-[10px] text-text-muted bg-bg/50 px-1.5 py-0.5 rounded">Warm</span>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">DAG pipeline: event collection, <strong class="text-text">story building</strong>, and continuous flushing to lower tiers. Real-time and elastic.</p>
          <div class="hidden md:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10 text-lime">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </div>
        </div>
        <!-- ChronoStore -->
        <div class="flex-1 bg-bg-card border border-lime/30 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-lime"></div>
            <h3 class="font-bold text-sm text-lime">ChronoStore</h3>
            <span class="text-[10px] text-text-muted bg-bg/50 px-1.5 py-0.5 rounded">Cold</span>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Persistent archival in <strong class="text-text">HDF5</strong> containers. Elastic capacity with device-aware access optimization.</p>
        </div>
      </div>

      <!-- ChronoPlayer spanning across -->
      <div class="bg-gradient-to-r from-lime/5 via-bg-card to-lime/5 border border-lime/20 rounded-xl p-5 mb-12">
        <div class="flex flex-col md:flex-row md:items-center gap-4">
          <div class="flex items-center gap-2 flex-shrink-0">
            <div class="w-2 h-2 rounded-full bg-lime"></div>
            <h3 class="font-bold text-sm text-lime">ChronoPlayer</h3>
            <span class="text-[10px] text-text-muted bg-bg/50 px-1.5 py-0.5 rounded">All tiers</span>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Reads span all tiers transparently. ChronoPlayer serves replay() requests from hot, warm, or cold storage and merges results into a single time-ordered stream. Fully decoupled from the write path.</p>
        </div>
      </div>

      <!-- Implementation highlights -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-bg-card border border-border rounded-lg p-4 text-center">
          <p class="text-lg font-bold text-lime mb-1">C++17</p>
          <p class="text-xs text-text-muted">Core implementation</p>
        </div>
