---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "ChronoLog",
  "description": "A distributed shared tiered log store that uses physical time as the ordering mechanism, enabling lock-free concurrent writes and auto-tiered storage across multiple layers.",
  "url": "https://chronolog.dev",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux",
  "softwareVersion": "1.0",
  "license": "https://opensource.org/licenses/BSD-2-Clause",
  "programmingLanguage": ["C++", "Python"],
  "codeRepository": "https://github.com/grc-iit/ChronoLog",
  "author": {
    "@type": "Organization",
    "name": "Gnosis Research Center",
    "url": "https://grc.iit.edu",
    "parentOrganization": {
      "@type": "EducationalOrganization",
      "name": "Illinois Institute of Technology",
      "url": "https://www.iit.edu"
    }
  },
  "funder": {
    "@type": "Organization",
    "name": "National Science Foundation",
    "url": "https://www.nsf.gov"
  },
  "funding": {
    "@type": "Grant",
    "identifier": "NSF CSSI-2104013",
    "funder": {
      "@type": "Organization",
      "name": "National Science Foundation"
    }
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const logos = [
  { src: '/images/logos/nsf.png', alt: 'National Science Foundation' },
  { src: '/images/logos/argonne.jpeg', alt: 'Argonne National Laboratory' },
  { src: '/images/logos/llnl.jpg', alt: 'Lawrence Livermore National Laboratory' },
  { src: '/images/logos/slac.png', alt: 'SLAC National Accelerator Laboratory' },
  { src: '/images/logos/iit.png', alt: 'Illinois Institute of Technology' },
  { src: '/images/logos/grc-logo.png', alt: 'Gnosis Research Center' },
  { src: '/images/logos/university-of-chicago.png', alt: 'University of Chicago' },
  { src: '/images/logos/university-of-illinois.jpg', alt: 'University of Illinois' },
  { src: '/images/logos/university-of-wisconsin.jpg', alt: 'University of Wisconsin' },
  { src: '/images/logos/depaul.png', alt: 'DePaul University' },
  { src: '/images/logos/omnibond.png', alt: 'Omnibond' },
  { src: '/images/logos/3red.png', alt: '3Red Partners' },
  { src: '/images/logos/paratools.png', alt: 'ParaTools' },
  { src: '/images/logos/parsl.svg', alt: 'Parsl' },
  { src: '/images/logos/ifsh.jpg', alt: 'Institute for Food Safety and Health' },
];
---

<Layout
  title="Home"
  description="ChronoLog is a distributed shared tiered log store that uses physical time as the ordering mechanism. NSF-funded open-source cyberinfrastructure for HPC, scientific computing, and AI agent memory."
  keywords="ChronoLog, distributed log, shared log, tiered storage, physical time ordering, HPC, activity data, NSF CSSI, MCP server, AI agent memory, RDMA, HDF5"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-lime/5 via-transparent to-slate-brand/10"></div>
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16 relative">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1 text-center md:text-left">
          <p class="text-lime font-semibold text-sm tracking-widest uppercase mb-3">NSF-Funded Cyberinfrastructure</p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-3">
            Distributed Shared<br />
            <span class="text-lime">Tiered Log Store</span>
          </h1>
          <p class="text-base text-text italic mb-4 max-w-xl">Activity data describe things that happen rather than things that are.</p>
          <p class="text-base text-text-muted leading-relaxed max-w-xl mb-4">
            ChronoLog is a distributed log storage ecosystem that uses <strong class="text-text">physical time</strong> as the ordering mechanism - eliminating centralized sequencers and enabling auto-tiered storage across multiple layers. Built to capture the velocity and variety of modern activity data: from scientific instruments producing terabytes per second to AI agent audit trails.
          </p>
          <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-2">
            {[
              { label: 'NSF CSSI Funded', color: 'bg-lime/10 text-lime border-lime/20' },
              { label: 'C++ & Python APIs', color: 'bg-slate-brand/20 text-text border-slate-brand/30' },
              { label: 'Plugin Ecosystem', color: 'bg-lime/10 text-lime border-lime/20' },
            ].map(stat => (
              <span class={`px-2.5 py-1 rounded-full text-xs font-medium border ${stat.color}`}>{stat.label}</span>
            ))}
          </div>
          <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-4">
            {[
              { label: 'MCP for AI Agents', color: 'bg-lime/10 text-lime border-lime/20' },
              { label: 'Docker Available', color: 'bg-slate-brand/20 text-text border-slate-brand/30' },
              { label: 'BSD-2 License', color: 'bg-slate-brand/20 text-text border-slate-brand/30' },
            ].map(stat => (
              <span class={`px-2.5 py-1 rounded-full text-xs font-medium border ${stat.color}`}>{stat.label}</span>
            ))}
          </div>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href="/docs/" class="inline-flex items-center gap-2 px-6 py-3 bg-lime text-charcoal font-semibold rounded-lg hover:bg-lime-light transition-colors">
              Explore the Docs
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="https://github.com/grc-iit/ChronoLog" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 border border-border text-text font-semibold rounded-lg hover:bg-white/5 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>
        <div class="flex-shrink-0 hidden md:block">
          <img src="/images/chronolog-full-logo-transparent.webp" alt="ChronoLog logo — distributed shared tiered log store" width="480" height="480" class="w-[20rem] lg:w-[24rem] drop-shadow-[0_0_30px_rgba(195,224,77,0.25)]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Collaborators & Partners -->
  <section class="border-y border-border bg-bg-alt/50 overflow-hidden">
    <div class="px-6 py-8">
      <p class="text-xs text-text-muted uppercase tracking-widest text-center mb-6">Collaborators & Partners</p>
      <div class="marquee-track">
        {[...logos, ...logos].map(logo => (
          <img src={logo.src} alt={logo.alt} class="h-16 min-w-[6rem] max-w-[10rem] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300 shrink-0" />
        ))}
      </div>
    </div>
  </section>

  <!-- Plugin & Connector Ecosystem -->
  <section class="border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">An Extensible Platform</h2>
      <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">ChronoLog is designed as a foundation that other systems build upon. Its extensible architecture supports <strong class="text-text">plugins</strong> for query, streaming, and storage workloads, and <strong class="text-text">AI integrations</strong> that connect the log to agents and LLM-based systems via protocols like MCP.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">SQL Query Plugin</h3>
          <p class="text-sm text-text-muted leading-relaxed">Query log data with familiar SQL semantics. Time-based ordering enables efficient range scans without auxiliary indices.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">Pub/Sub & Streaming</h3>
          <p class="text-sm text-text-muted leading-relaxed">Publish-subscribe patterns and real-time streaming built on ChronoGrapher's DAG pipeline. Used internally by IOWarp.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">Key-Value Store</h3>
          <p class="text-sm text-text-muted leading-relaxed">ChronoKVS provides time-series key-value semantics on top of the ordered log, with built-in consistency guarantees.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">ML & Training</h3>
          <p class="text-sm text-text-muted leading-relaxed">TensorFlow integration for feeding time-ordered data streams directly into training and inference pipelines.</p>
        </div>
      </div>
      <div class="mt-10 bg-gradient-to-r from-lime/5 via-bg-card to-lime/5 border border-lime/20 rounded-2xl p-8 md:p-10">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-center">
          <div class="md:col-span-3">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 rounded-lg bg-lime/15 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
              </div>
              <h2 class="text-xl md:text-2xl font-bold">ChronoLog for AI Agent Memory</h2>
            </div>
            <p class="text-text-muted leading-relaxed mb-4">
              AI agents need persistent, time-ordered memory. ChronoLog provides exactly that -- a distributed log that serves as the <strong class="text-text">shared memory backend</strong> for autonomous agents, LLM-based systems, and agentic workflows. Every agent action, observation, and reasoning step can be recorded as a time-stamped chronicle entry, creating a queryable audit trail across conversations and sessions.
            </p>
            <p class="text-text-muted leading-relaxed mb-5">
              The official <strong class="text-text">ChronoLog MCP server</strong>, part of the IOWarp Agent Toolkit, exposes chronicle operations as Model Context Protocol tools -- so any MCP-compatible AI agent can create logs, record events, replay history, and query by time range natively.
            </p>
            <a href="https://github.com/iowarp/agent-toolkit/tree/main/agent-toolkit-mcp-servers/chronolog" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-lime text-charcoal text-sm font-semibold rounded-lg hover:bg-lime-light transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              ChronoLog MCP Server
            </a>
          </div>
          <div class="md:col-span-2 bg-bg rounded-xl p-5 border border-border/50 font-mono text-xs text-text-muted leading-relaxed">
            <p class="text-lime mb-2">// Agent memory via MCP</p>
            <p class="mb-1"><span class="text-slate-light">tools:</span></p>
            <p class="mb-1 pl-3">chronicle.create <span class="text-text-muted">- new memory log</span></p>
            <p class="mb-1 pl-3">chronicle.record <span class="text-text-muted">- store event</span></p>
            <p class="mb-1 pl-3">chronicle.replay <span class="text-text-muted">- retrieve history</span></p>
            <p class="mb-3 pl-3">chronicle.query  <span class="text-text-muted">- search by time</span></p>
            <p class="text-lime mb-2">// Use cases</p>
            <p class="mb-1 pl-3">- Conversation logging</p>
            <p class="mb-1 pl-3">- Agent audit trails</p>
            <p class="mb-1 pl-3">- Cross-session memory</p>
            <p class="pl-3">- System monitoring</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Community & Adoption -->
  <section class="bg-bg-alt border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">Community & Adoption</h2>
      <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">ChronoLog's impact extends beyond its codebase. From graduate classrooms to national lab clusters, the project has a growing community of researchers, students, and collaborators.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-5 mb-12">
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">300+</div>
          <p class="text-xs text-text-muted leading-tight">Attendees at ChronoLog presentations, webinars, and classroom sessions</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">2,000+</div>
          <p class="text-xs text-text-muted leading-tight">GitHub visitors per year, with growing adoption across research communities</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">15+</div>
          <p class="text-xs text-text-muted leading-tight">PhD researchers using ChronoLog as a backend for distributed logging</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">5+</div>
          <p class="text-xs text-text-muted leading-tight">Cluster installations, including GRC and DOE partner sites</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">3</div>
          <p class="text-xs text-text-muted leading-tight">Active community domains: FaaS, scientific data repositories, and system telemetry</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-bg-card border border-border rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>
            <h3 class="font-semibold text-sm text-text">Taught in the Classroom</h3>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Used as teaching infrastructure in distributed systems and HPC graduate courses at IIT. Students learn real-world distributed log design using ChronoLog's APIs and deployment tools.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>
            <h3 class="font-semibold text-sm text-text">Cross-Disciplinary Research</h3>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Beyond HPC, ChronoLog has been applied in nutrition analysis (with IIT's Department of Food Science) and genomic sequencing pipelines, demonstrating its versatility across domains.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7"/></svg>
            <h3 class="font-semibold text-sm text-text">Deployed on Clusters</h3>
          </div>
          <p class="text-xs text-text-muted leading-relaxed">Active installations on the GRC research cluster and available at DOE partner sites. Used for continuous research workloads including HPC system monitoring and provenance tracking.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Get Involved -->
  <section>
    <div class="max-w-4xl mx-auto px-6 py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Involved</h2>
      <p class="text-text-muted leading-relaxed mb-8 max-w-2xl mx-auto">
        ChronoLog is open source and welcoming collaborators. Whether you're a researcher exploring distributed log abstractions, a developer building on the plugin ecosystem, or an institution looking for scalable logging infrastructure -- we'd like to hear from you.
