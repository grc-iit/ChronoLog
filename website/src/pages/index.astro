---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "ChronoLog",
  "description": "A distributed shared tiered log store that uses physical time as the ordering mechanism, enabling lock-free concurrent writes and auto-tiered storage across multiple layers.",
  "url": "https://chronolog.dev",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux",
  "softwareVersion": "2.4.0",
  "license": "https://opensource.org/licenses/BSD-2-Clause",
  "programmingLanguage": ["C++", "Python"],
  "codeRepository": "https://github.com/grc-iit/ChronoLog",
  "author": {
    "@type": "Organization",
    "name": "Gnosis Research Center",
    "url": "https://grc.iit.edu",
    "parentOrganization": {
      "@type": "EducationalOrganization",
      "name": "Illinois Institute of Technology",
      "url": "https://www.iit.edu"
    }
  },
  "funder": {
    "@type": "Organization",
    "name": "National Science Foundation",
    "url": "https://www.nsf.gov"
  },
  "funding": {
    "@type": "Grant",
    "identifier": "NSF CSSI-2104013",
    "funder": {
      "@type": "Organization",
      "name": "National Science Foundation"
    }
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const logos = [
  { src: '/images/logos/nsf.png', alt: 'National Science Foundation' },
  { src: '/images/logos/argonne.jpeg', alt: 'Argonne National Laboratory' },
  { src: '/images/logos/llnl.jpg', alt: 'Lawrence Livermore National Laboratory' },
  { src: '/images/logos/slac.png', alt: 'SLAC National Accelerator Laboratory' },
  { src: '/images/logos/iit.png', alt: 'Illinois Institute of Technology' },
  { src: '/images/logos/grc-logo.png', alt: 'Gnosis Research Center' },
  { src: '/images/logos/university-of-chicago.png', alt: 'University of Chicago' },
  { src: '/images/logos/university-of-illinois.jpg', alt: 'University of Illinois' },
  { src: '/images/logos/university-of-wisconsin.jpg', alt: 'University of Wisconsin' },
  { src: '/images/logos/depaul.png', alt: 'DePaul University' },
  { src: '/images/logos/omnibond.png', alt: 'Omnibond' },
  { src: '/images/logos/3red.png', alt: '3Red Partners' },
  { src: '/images/logos/paratools.png', alt: 'ParaTools' },
  { src: '/images/logos/parsl.svg', alt: 'Parsl' },
  { src: '/images/logos/ifsh.jpg', alt: 'Institute for Food Safety and Health' },
];
---

<Layout
  title="Home"
  description="ChronoLog is a distributed shared tiered log store that uses physical time as the ordering mechanism. NSF-funded open-source cyberinfrastructure for HPC, scientific computing, and AI agent memory."
  keywords="ChronoLog, distributed log, shared log, tiered storage, physical time ordering, HPC, activity data, NSF CSSI, MCP server, AI agent memory, RDMA, HDF5"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-lime/5 via-transparent to-slate-brand/10"></div>
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16 relative">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1 text-center md:text-left">
          <p class="text-lime font-semibold text-sm tracking-widest uppercase mb-3">NSF-Funded Cyberinfrastructure</p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-3">
            Distributed Shared<br />
            <span class="text-lime">Tiered Log Store</span>
          </h1>
          <p class="text-base text-text italic mb-4 max-w-xl">Activity data describe things that happen rather than things that are.</p>
          <p class="text-base text-text-muted leading-relaxed max-w-xl mb-4">
            ChronoLog is a distributed log storage ecosystem that uses <strong class="text-text">physical time</strong> as the ordering mechanism - eliminating centralized sequencers and enabling auto-tiered storage across multiple layers. Built to capture the velocity and variety of modern activity data: from scientific instruments producing terabytes per second to AI agent audit trails.
          </p>
          <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-2">
            {[
              { label: 'NSF CSSI Funded', color: 'bg-lime/10 text-lime border-lime/20' },
              { label: 'C++ & Python APIs', color: 'bg-slate-brand/20 text-text border-slate-brand/30' },
              { label: 'Plugin Ecosystem', color: 'bg-lime/10 text-lime border-lime/20' },
            ].map(stat => (
              <span class={`px-2.5 py-1 rounded-full text-xs font-medium border ${stat.color}`}>{stat.label}</span>
            ))}
          </div>
          <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-4">
            {[
              { label: 'MCP for AI Agents', color: 'bg-lime/10 text-lime border-lime/20' },
              { label: 'Docker Available', color: 'bg-slate-brand/20 text-text border-slate-brand/30' },
              { label: 'BSD-2 License', color: 'bg-slate-brand/20 text-text border-slate-brand/30' },
            ].map(stat => (
              <span class={`px-2.5 py-1 rounded-full text-xs font-medium border ${stat.color}`}>{stat.label}</span>
            ))}
          </div>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href="https://docs.chronolog.dev" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-lime text-charcoal font-semibold rounded-lg hover:bg-lime-light transition-colors">
              Explore the Docs
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="https://github.com/grc-iit/ChronoLog" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 border border-border text-text font-semibold rounded-lg hover:bg-white/5 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>
        <div class="flex-shrink-0 hidden md:block">
          <img src="/images/chronolog-full-logo-transparent.webp" alt="ChronoLog logo — distributed shared tiered log store" width="480" height="480" class="w-[20rem] lg:w-[24rem] drop-shadow-[0_0_30px_rgba(195,224,77,0.25)]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Collaborators & Partners -->
  <section class="border-y border-border overflow-hidden">
    <div class="px-6 py-8">
      <p class="text-xs text-text-muted uppercase tracking-widest text-center mb-6">Collaborators & Partners</p>
      <div class="marquee-track">
        {[...logos, ...logos].map(logo => (
          <img src={logo.src} alt={logo.alt} class="h-16 min-w-[6rem] max-w-[10rem] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300 shrink-0" />
        ))}
      </div>
    </div>
  </section>

  <!-- What Makes ChronoLog Different -->
  <section class="border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">What Makes ChronoLog Different</h2>
      <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">Traditional distributed logs rely on centralized sequencers and consensus protocols to order events. ChronoLog takes a fundamentally different approach.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2">Physical Time Ordering</h3>
          <p class="text-sm text-text-muted leading-relaxed">Uses synchronized physical clocks instead of Paxos/Raft consensus to order events. No centralized sequencer bottleneck.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2">Lock-Free Concurrent Writes</h3>
          <p class="text-sm text-text-muted leading-relaxed">Multiple distributed writers append simultaneously without coordination. I/O paths are fully isolated between processes.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2">Auto-Tiered Storage</h3>
          <p class="text-sm text-text-muted leading-relaxed">Data moves automatically across hot, warm, and cold storage tiers. Elastic capacity without manual data management.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2">Immediate Visibility</h3>
          <p class="text-sm text-text-muted leading-relaxed">Events are visible to readers as soon as they are written. Total ordering with concurrent access at scale.</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/how-it-works/" class="inline-flex items-center gap-2 text-sm text-lime font-medium hover:underline">
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Architecture Overview -->
  <section class="bg-bg-alt border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">How It Works</h2>
      <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">ChronoLog separates ingestion, ordering, persistence, and replay into five specialized services that form a tiered pipeline.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-text font-bold text-lg mb-1">ChronoVisor</div>
          <p class="text-xs text-text-muted">Coordination & clock synchronization</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-text font-bold text-lg mb-1">ChronoKeeper</div>
          <p class="text-xs text-text-muted">Fast ingestion via RDMA (hot tier)</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-text font-bold text-lg mb-1">ChronoGrapher</div>
          <p class="text-xs text-text-muted">Event assembly & story building (warm tier)</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-text font-bold text-lg mb-1">ChronoStore</div>
          <p class="text-xs text-text-muted">Persistent archival in HDF5 (cold tier)</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-text font-bold text-lg mb-1">ChronoPlayer</div>
          <p class="text-xs text-text-muted">Cross-tier reads & replay</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/how-it-works/" class="inline-flex items-center gap-2 text-sm text-lime font-medium hover:underline">
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Plugin & Connector Ecosystem -->
  <section class="border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">An Extensible Platform</h2>
      <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">ChronoLog is designed as a foundation that other systems build upon. Its plugin architecture supports query, streaming, storage, and AI integration workloads.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        <a href="/integrations/" class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group block">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">SQL Query</h3>
          <p class="text-sm text-text-muted leading-relaxed">Familiar SQL semantics over time-ordered log data.</p>
        </a>
        <a href="/integrations/" class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group block">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">Pub/Sub & Streaming</h3>
          <p class="text-sm text-text-muted leading-relaxed">Real-time event streaming via ChronoGrapher's DAG pipeline.</p>
        </a>
        <a href="/integrations/" class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group block">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">Key-Value Store</h3>
          <p class="text-sm text-text-muted leading-relaxed">Time-series KV semantics with built-in ordering guarantees.</p>
        </a>
        <a href="/integrations/" class="bg-bg-card border border-border rounded-xl p-6 hover:border-lime/40 transition-colors group block">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">ML & Training</h3>
          <p class="text-sm text-text-muted leading-relaxed">TensorFlow integration for time-ordered data pipelines.</p>
        </a>
        <a href="/integrations/" class="bg-bg-card border border-lime/20 rounded-xl p-6 hover:border-lime/40 transition-colors group block">
          <div class="w-10 h-10 rounded-lg bg-lime/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
          </div>
          <h3 class="font-semibold text-text mb-2 group-hover:text-lime transition-colors">AI Agent Memory</h3>
          <p class="text-sm text-text-muted leading-relaxed">MCP server for persistent agent memory and audit trails.</p>
        </a>
      </div>
      <div class="text-center mt-8">
        <a href="/integrations/" class="inline-flex items-center gap-2 text-sm text-lime font-medium hover:underline">
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Project at a Glance -->
  <section class="bg-bg-alt border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">Project at a Glance</h2>
      <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">ChronoLog is a multi-year research effort backed by the National Science Foundation and developed in partnership with DOE national laboratories and universities.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-5 mb-12">
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">$4M</div>
          <p class="text-xs text-text-muted leading-tight">NSF CSSI grant funding</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">5</div>
          <p class="text-xs text-text-muted leading-tight">Peer-reviewed publications at top-tier venues (SC, MSST, CLUSTER, IPDPS, ICS)</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">4+</div>
          <p class="text-xs text-text-muted leading-tight">Years of active development since 2020</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-3xl font-extrabold text-lime mb-1">10+</div>
          <p class="text-xs text-text-muted leading-tight">Partner institutions including DOE national labs, universities, and industry</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="w-full flex items-center justify-center mb-1">
            <svg class="w-8 h-8 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7"/></svg>
          </div>
          <p class="text-xs text-text-muted leading-tight">Deployed at national laboratory partner sites and university clusters</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-bg-card border border-border rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
