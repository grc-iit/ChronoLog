---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Releases"
  description="Download ChronoLog releases and artifacts: Docker images, pre-built binaries, release notes, and source code."
  keywords="ChronoLog releases, downloads, Docker, artifacts, GitHub releases, installation"
>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Releases & Downloads</h1>
    <p class="text-text-muted text-lg max-w-3xl leading-relaxed">
      Official ChronoLog releases with pre-built binaries, RPM/DEB packages, Docker images, and documentation.
      For installation and deployment instructions, see the <a href="https://chronolog.dev/docs/" target="_blank" rel="noopener noreferrer" class="text-lime hover:underline">documentation</a>.
      For the full release history, visit <a href="https://github.com/grc-iit/ChronoLog/releases" target="_blank" rel="noopener noreferrer" class="text-lime hover:underline">GitHub Releases</a>.
    </p>
  </section>

  <!-- Release table -->
  <section class="bg-bg-alt border-y border-border">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="text-2xl md:text-3xl font-bold mb-8">Releases</h2>

      <div class="bg-bg-card border border-border rounded-xl p-6 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border text-left">
              <th class="pb-3 pr-4 font-semibold text-text">Version</th>
              <th class="pb-3 font-semibold text-text-muted text-right">Resources</th>
            </tr>
          </thead>
          <tbody class="text-text-muted">
            <!-- v2.5.1 -->
            <tr class="align-top">
              <td class="py-4 pr-4">
                <div class="font-semibold text-text">v2.5.1</div>
                <div class="text-xs text-text-muted mt-1">2026-04-17</div>
                <span class="inline-block mt-1 px-2 py-0.5 bg-lime/15 text-lime text-xs font-semibold rounded">Latest</span>
              </td>
              <td class="py-4">
                <div class="flex items-center justify-end gap-2">
                  <a href="https://github.com/grc-iit/ChronoLog/releases/tag/v2.5.1" target="_blank" rel="noopener noreferrer" title="Pre-built binary" class="inline-flex items-center justify-center w-8 h-8 rounded-lg border border-border hover:border-lime/40 hover:bg-lime/10 transition-colors text-text-muted hover:text-lime">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
                  </a>
